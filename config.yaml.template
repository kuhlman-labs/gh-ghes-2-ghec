server:
  port: 8080
  shutdown_timeout: 30
  read_timeout: 15
  write_timeout: 15
  rate_limit: 60  # 60 requests per minute

webhook:
  url: ""  # Set this to your webhook URL if needed

logging:
  level: "info"  # debug, info, warn, error

tracing:
  enabled: false  # Set to true to enable OpenTelemetry tracing
  endpoint: "localhost:4317"  # OTLP endpoint
  service_name: "gh-ghes-2-ghec"
  sample_rate: 1.0  # Sample all traces (1.0) or a fraction (e.g., 0.1 for 10%) 